# Server
PORT=3001
NODE_ENV=development

# API Keys (replace with real values)
YANDEX_GPT_API_KEY=your_yandex_gpt_key
YANDEX_GPT_FOLDER_ID=your_folder_id
# Генерация сказки: completion (Foundation Models, по умолчанию) | alice (AI Studio Responses, Alice LLM)
# YANDEX_STORY_BACKEND=alice
# YANDEX_ALICE_MODEL=aliceai-llm/latest
# Полный model, если в консоли другой формат:
# YANDEX_ALICE_MODEL_URI=gpt://your_folder_id/aliceai-llm/latest
# YANDEX_ALICE_TEMPERATURE=0.78
# YANDEX_ALICE_MAX_OUTPUT_TOKENS=8192
# При необходимости другой endpoint (обычно не нужно):
# YANDEX_AI_RESPONSES_URL=https://ai.api.cloud.yandex.net/v1/responses
# Опционально: полный modelUri или суффикс после gpt://<folder>/
# YANDEX_GPT_MODEL_URI=gpt://your_folder_id/yandexgpt/latest
# Другие модели каталога Yandex — только если в консоли указан тот же формат gpt://... для v1/completion:
# YANDEX_GPT_MODEL_URI=gpt://your_folder_id/<имя_модели_из_галереи>/latest
# YANDEX_GPT_MODEL=yandexgpt-lite/latest
REPLICATE_API_TOKEN=your_replicate_token

# Kie.ai — FLUX.1 Kontext (https://kie.ai/, документация: https://docs.kie.ai/flux-kontext-api/quickstart)
# Важно: для inputImage нужен публичный URL вашего /uploads/... — выставьте BASE_URL на доступный из интернета адрес (или туннель ngrok/localtunnel).
KIE_AI_API_KEY=your_kie_ai_api_key
# При наличии и KIE_AI_API_KEY и REPLICATE_API_TOKEN по умолчанию используется Kie.
# Принудительно: kie | replicate | none (none — только заглушки, без Kie/Replicate; удобно тестировать текст)
IMAGE_GEN_PROVIDER=kie
KIE_FLUX_MODEL=flux-kontext-pro
# flux-kontext-max — усложнённые сцены (дороже/дольше по тарифам Kie)
# KIE_FLUX_MODEL=flux-kontext-max
KIE_FLUX_ASPECT_RATIO=3:4
KIE_FLUX_OUTPUT_FORMAT=png
# true — если промпт не на английском (в проекте сцены обычно уже EN)
KIE_FLUX_ENABLE_TRANSLATION=false
KIE_AI_POLL_MAX_MS=300000

# Replicate — Flux + PuLID (bytedance/flux-pulid): лицо с main_face_image, сцена из prompt
# Полный идентификатор с версией: bytedance/flux-pulid:<hash_версии>
REPLICATE_FLUX_PULID_MODEL=bytedance/flux-pulid
REPLICATE_FLUX_PULID_WIDTH=896
REPLICATE_FLUX_PULID_HEIGHT=1195
REPLICATE_FLUX_PULID_NUM_STEPS=20
# для стилизованных иллюстраций README рекомендует 0–1; для реализма — выше
REPLICATE_FLUX_PULID_START_STEP=1
REPLICATE_FLUX_PULID_GUIDANCE_SCALE=4
REPLICATE_FLUX_PULID_ID_WEIGHT=1

# Storage
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
OUTPUT_DIR=./output
# Опционально: абсолютный путь к .ttf с кириллицей, если шрифт не в kidfacebook-api/fonts/

# PDF_CYRILLIC_FONT_PATH=

# Limits
MAX_FILE_SIZE=10485760
MAX_FILES=3

# Base URL: локально http://localhost:3001; на Render — https://kidsfacebook.onrender.com (или ваш хост)
BASE_URL=http://localhost:3001

# Дополнительные разрешённые origins (через запятую). Запросы с vk.com / *.vk-apps.com разрешены всегда в production.
# CORS_ORIGINS=https://kids-book.example.com
